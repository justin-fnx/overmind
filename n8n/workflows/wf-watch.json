      {
        "id": "91e7e1de-2754-40d8-8c58-33c5ae851bb7",
        "name": "디스패치 판정",
        "parameters": {
          "jsCode": "const completed=new Set();$('완료 조회').all().forEach(function(it){var id=String(it.json.id||'').replace(/-/g,'');if(id)completed.add(id);});const createdMap={};$('created 조회').all().forEach(function(it){var r=it.json;if(r.subtask_page_id){createdMap[String(r.parent_page_id||'').replace(/-/g,'')+'|'+r.stage]=String(r.subtask_page_id).replace(/-/g,'');}});const out=[];const seen={};$('pending 조회').all().forEach(function(it){var row=it.json;var parent=String(row.parent_page_id||'').replace(/-/g,'');var key=parent+'|'+row.stage;if(createdMap[key])return;if(seen[key])return;var deps=[];try{deps=JSON.parse(row.depends_on||'[]');}catch(e){deps=[];}var ready=deps.length>0&&deps.every(function(dep){var sid=createdMap[parent+'|'+dep];return sid&&completed.has(sid);});if(ready){seen[key]=1;out.push({json:{rowId:row.id,parentPageId:row.parent_page_id,stage:row.stage,persona:row.persona,pipeline:row.pipeline,pageId:row.parent_page_id,title:row.title,brief:row.brief,qa:row.qa,channelId:row.channel_id,threadTs:row.thread_ts}});}});return out;"
        },
        "position": [
          660,
          300
        ],
        "type": "n8n-nodes-base.code",
        "typeVersion": 2
      },
      {
        "id": "626c5c87-e396-4666-80a0-ef26aaac4ba2",
        "name": "WF3 호출",
        "parameters": {
          "jsonBody": "={{ {pageId:$json.pageId,title:$json.title,brief:$json.brief,qa:$json.qa,stage:$json.stage,persona:$json.persona,pipeline:$json.pipeline,channelId:$json.channelId,threadTs:$json.threadTs} }}",
          "method": "POST",
          "options": {
