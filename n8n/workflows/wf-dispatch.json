    {
      "id": "b41035ee-dc9b-4604-8dc9-d3103d77adc4",
      "name": "디스패치 통보 메시지",
      "parameters": {
        "jsCode": "const stages=(($('단계 계획').first().json.output)||{}).stages||[];const c=$('계획 입력').first().json;const existing={};$('기존 단계 조회').all().forEach(function(it){var s=it.json&&it.json.stage;if(s)existing[s]=1;});const fresh=stages.filter(function(s){return !existing[s.stage];});const skipped=stages.filter(function(s){return existing[s.stage];}).map(function(s){return s.stage;});const ready=fresh.filter(function(s){return !((s.dependsOn||[]).length);}).map(function(s){return s.stage;});const pend=fresh.filter(function(s){return (s.dependsOn||[]).length;}).map(function(s){return s.stage+'(←'+s.dependsOn.join(',')+')';});var text='🧩 ['+c.title+'] 단계 디스패치\\n• 즉시 생성: '+(ready.join(', ')||'없음')+'\\n• 대기(의존): '+(pend.join(', ')||'없음');if(skipped.length)text+='\\n• 건너뜀(이미 존재): '+skipped.join(', ');return [{json:{body:{channel:c.channelId,thread_ts:c.threadTs,text:text}}}];"
      },
      "position": [
        700,
        440
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
