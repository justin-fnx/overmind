    {
      "id": "7a3fa5b0-e5a7-4be4-830e-9d87483d8b10",
      "name": "분류",
      "parameters": {
        "jsCode": "const stages=(($('단계 계획').first().json.output)||{}).stages||[];const c=$('계획 입력').first().json;const existing={};$('기존 단계 조회').all().forEach(function(it){var s=it.json&&it.json.stage;if(s)existing[s]=1;});const fresh=stages.filter(function(s){return !existing[s.stage];});const pipeline=stages.map(function(s){return s.stage;}).join(' → ');const P={'리서치':'UX 리서처','디자인':'시니어 프로덕트 디자이너','개발':'시니어 소프트웨어 개발자','프론트엔드':'시니어 프론트엔드 개발자','백엔드':'시니어 백엔드 개발자','QA':'QA 엔지니어','마케팅':'그로스 마케터'};return fresh.map(function(s){var dep=s.dependsOn||[];return {json:{stage:s.stage,persona:s.persona||P[s.stage]||(s.stage+' 담당자'),pipeline:pipeline,dependsOn:JSON.stringify(dep),ready:(dep.length===0),pageId:c.pageId,title:c.title,brief:c.brief,qa:c.qa,channelId:c.channelId,threadTs:c.threadTs}};});"
      },
      "position": [
        700,
        200
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
