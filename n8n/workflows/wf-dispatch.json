      "id": "e9ad4847-deb1-42d4-abb7-09626d4ddb0f",
      "name": "계획 입력",
      "parameters": {
        "jsCode": "const b=$json.body||$json;return [{json:{pageId:b.pageId,title:b.title,brief:b.brief||'',qa:b.qa||'',roles:b.roles||[],channelId:b.channelId,threadTs:b.threadTs}}];"
