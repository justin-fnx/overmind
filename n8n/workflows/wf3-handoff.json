    {
      "id": "2ac5f54a-8591-42fb-9e0f-12fc95c99435",
      "name": "착수 카드 메뉴",
      "parameters": {
        "jsCode": "const all = $(\"착수 허브 조회\").all();\nconst menu = all.map(function(c){ var p=c.json.properties||{}; var subj=(p.주제&&p.주제.title&&p.주제.title[0])?p.주제.title[0].plain_text:\"\"; var area=(p.영역&&p.영역.select)?p.영역.select.name:\"\"; var tier=(p.계층&&p.계층.select)?p.계층.select.name:\"\"; return subj ? (\"- [\"+subj+\"] 영역:\"+area+\" / \"+tier+\" / id:\"+c.json.id) : \"\"; }).filter(Boolean).join(\"\\n\");\nreturn [{ json: { menu: menu } }];"
      },
