    {
      "id": "31698a12-0a4f-453f-b8be-2bca307be38c",
      "name": "스테이지·페르소나 결정",
      "parameters": {
        "jsCode": "const ri = $json;\nconst roles = ri.roles || [];\nconst ORDER = [\"리서치\", \"디자인\", \"개발\", \"QA\", \"마케팅\"];\nconst PERSONA = { \"리서치\": \"UX 리서처\", \"디자인\": \"시니어 프로덕트 디자이너\", \"개발\": \"시니어 소프트웨어 개발자\", \"QA\": \"QA 엔지니어\", \"마케팅\": \"그로스 마케터\" };\nconst norm = roles.map(function (r) { return String(r).split(\"/\")[0].trim(); });\nconst ordered = ORDER.filter(function (s) { return norm.indexOf(s) !== -1; });\nconst first = ordered.length ? ordered[0] : (norm[0] || \"개발\");\nconst persona = PERSONA[first] || (first + \" 담당자\");\nreturn [{ json: { stage: first, persona: persona, pipeline: ordered.join(\" \\u2192 \"), pageId: ri.pageId, title: ri.title, threadTs: ri.threadTs, channelId: ri.channelId, brief: ri.brief } }];"
      },
      "position": [
        240,
        300
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "credentials": {
        "notionApi": {
